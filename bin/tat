#!/bin/bash
#
# Attach or create tmux session named the same as current directory.
# When a smug config exists for the session, uses smug to create it.

path_name="$(basename "$PWD" | tr . -)"
session_name=$TMUX_DEFAULT_SESSION_NAME

if [ -z $session_name ]; then
  session_name=${1-$path_name}
fi


not_in_tmux() {
    [ -z "$TMUX" ]
}

session_exists() {
    tmux list-sessions | sed -E 's/:.*$//' | grep -q "^$session_name$"
}

smug_config() {
    local name="$(echo "$session_name" | tr '[:upper:]' '[:lower:]')"
    if [ -f "$HOME/.config/smug/${name}.yml" ]; then
        echo "$name"
    fi
}

create_with_smug() {
    local config="$(smug_config)"
    if [ -n "$config" ]; then
        (TMUX='' smug start "$config" --detach)
        return 0
    fi
    return 1
}

create_if_needed_and_attach() {
    if not_in_tmux; then
        if ! session_exists; then
            local config="$(smug_config)"
            if [ -n "$config" ]; then
                smug start "$config"
                return
            fi
        fi
        tmux new-session -As "$session_name"
    else
        if ! session_exists; then
            create_with_smug || (TMUX='' tmux new-session -Ad -s "$session_name")
        fi
        tmux switch-client -t "$session_name"
    fi
}

create_if_needed_and_attach
