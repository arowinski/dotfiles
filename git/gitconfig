[core]
  editor = nvim
  excludesfile = ~/.gitignore
  autocrlf = input
  pager = delta
[delta]
  features = diff-so-fancy
  navigate = true
[rerere]
  enabled = true
[color]
  ui = auto
[color "status"]
  added = yellow
  changed = green
  untracked = cyan
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[merge]
  ff = only
[push]
  default = current
  autoSetupRemote = true
[fetch]
  prune = true
[rebase]
  autosquash = true
[pull]
  ff = only
[diff]
  colorMoved = zebra
[user]
  name = arowinski
  email = arowinski02@gmail.com
[interactive]
  diffFilter = delta --color-only
