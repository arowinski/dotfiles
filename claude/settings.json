{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(~/.local/share/mise/*)",
      "Read(~/gat/*)",
      "Grep(~/gat/*)",
      "Glob(~/gat/*)",
      "Search(~/gat/*)",
      "Write(~/.claude/retro-log.md)",
      "Edit(~/.claude/retro-log.md)",
      "Write(*/claude/plans/*)",
      "Edit(*/claude/plans/*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(pwd:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(file:*)",
      "Bash(date:*)",
      "Bash(test:*)",
      "Bash(touch:*)",
      "Bash(mkdir:*)",
      "Bash(git mv:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git stash show:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run watch:*)",
      "Bash(gh-comments:*)",
      "Bash(coderabbit:*)",
      "Bash(just:*)",
      "Bash(safe-python:*)",
      "Bash(claude-retro:*)",
      "Bash(dev:*)",
      "Bash(tmux:*)",
      "Bash(smug:*)",
      "Bash(rubocop:*)",
      "Bash(bin/spring:*)",
      "Bash(spring:*)",
      "Bash(bin/rails db:migrate:status:*)",
      "Bash(bin/rails runner:*)",
      "Bash(bin/packwerk check:*)",
      "Bash(yarn run:*)",
      "Bash(yarn test:*)",
      "Bash(npx playwright test:*)",
      "Bash(mix compile:*)",
      "Bash(mix test:*)",
      "Bash(mix format:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(bundle exec rails runner:*)",
      "Bash(bundle show:*)",
      "Bash(bundle info:*)",
      "Skill(*)",
      "mcp__context7__*",
      "mcp__tidewave__*",
      "mcp__sentry__*",
      "mcp__db__*",
      "mcp__db_hive__*",
      "mcp__db_tracker__*",
      "mcp__db_model__*",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__getAccessibleAtlassianResources",
      "mcp__atlassian__search",
      "mcp__atlassian__fetch",
      "mcp__atlassian__atlassianUserInfo",
      "mcp__atlassian__getVisibleJiraProjects",
      "mcp__atlassian__getTransitionsForJiraIssue",
      "mcp__atlassian__getIssueLinkTypes",
      "mcp__atlassian__lookupJiraAccountId"
    ],
    "deny": [
      "Read(~/gat/gat-local/*.env)",
      "Grep(~/gat/gat-local/*.env)",
      "Glob(~/gat/gat-local/*.env)",
      "Search(~/gat/gat-local/*.env)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "dippy"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "coderabbit@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "enabled": false
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "effortLevel": "high"
}
