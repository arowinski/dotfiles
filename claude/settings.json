{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(~/.local/share/mise/*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(echo:*)",
      "Bash(which:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run watch:*)",
      "Bash(gh-comments:*)",
      "Bash(coderabbit:*)",
      "Bash(just:*)",
      "Bash(npx playwright test:*)",
      "Bash(mix compile:*)",
      "Bash(mix test:*)",
      "Bash(mix format:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(bundle show:*)",
      "Bash(bundle info:*)",
      "Skill(*)",
      "mcp__context7__*",
      "mcp__sentry__*",
      "mcp__db__*",
      "mcp__db_hive__*",
      "mcp__db_tracker__*",
      "mcp__db_model__*"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-claude"
          }
        ]
      }
    ],
    "SessionStart": []
  },
  "enabledPlugins": {
    "coderabbit@claude-plugins-official": true,
    "claude-permissions-plugin@broven-claude-permissions-plugin": true
  },
  "sandbox": {
    "enabled": false
  },
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest"
}
