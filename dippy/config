# Mutations explicitly allowed in Claude Code settings.json
# Dippy's built-in handlers consider these unsafe, but they're
# standard workflow commands that shouldn't require prompting.

# Git mutations
allow git add
allow git commit
allow git switch
allow git pull
allow git stash
allow git mv
allow git absorb
allow git rebase
allow GIT_SEQUENCE_EDITOR=* git rebase *
allow GIT_EDITOR=* git rebase *
allow GIT_SEQUENCE_EDITOR=* GIT_EDITOR=* git rebase *
allow git branch
allow git checkout
ask git checkout [!-]* "Use git switch for branch operations"

# Filesystem
allow touch
allow mkdir
allow-redirect /tmp/**
allow-redirect /private/tmp/**

# Project tools
allow mix
allow MIX_ENV=* mix *
allow PATH=* mix *
allow POSTGRES_DBNAME=* mix *
allow just
allow RAILS_ENV=* just *
allow CI=* just *
allow bundle exec rspec
allow bundle exec rubocop
allow bundle exec rails runner
allow bundle exec rails db:prepare
allow bundle exec rails db:migrate
allow RAILS_ENV=test bundle exec rails db:drop
allow RAILS_ENV=test bundle exec rails db:prepare
allow RAILS_ENV=* bundle exec rails db:schema:dump
deny bundle exec rails db:create "Use db:prepare instead"
deny bundle exec rails db:schema:load "Use db:prepare instead"
allow bin/spring
allow spring
allow bin/rails db:migrate
allow bin/rails db:prepare
allow bin/rails graphql:schema:json
allow bin/rails runner
allow RAILS_ENV=* bin/rails *
allow rails runner
allow bin/packwerk check
allow bin/packwerk validate
allow yarn run
allow yarn test
allow pg_dump
allow psql
ask psql *CREATE * "Confirm: psql DDL (CREATE)"
ask psql *DROP * "Confirm: psql DDL (DROP)"
ask psql *DELETE * "Confirm: psql DML write (DELETE)"
ask psql *TRUNCATE * "Confirm: psql DDL (TRUNCATE)"
ask psql *ALTER * "Confirm: psql DDL (ALTER)"
ask psql *-f * "Confirm: psql executes file — verify contents"
ask psql *--file * "Confirm: psql executes file — verify contents"
ask psql *--file=* "Confirm: psql executes file — verify contents"
allow npx playwright test
allow git-commit-context
allow safe-python
allow safe-ruby
deny python3 "Use safe-python instead of python3"
deny ruby "Use safe-ruby for one-liners, rails runner in Rails projects"
deny elixir -e "Use mix run -e for project context, or iex -S mix"
ask sed *-i* "Use Edit tool for file modifications; sed -i bypasses diff review"
ask sed *--in-place* "Use Edit tool for file modifications; sed --in-place bypasses diff review"
allow claude-retro
allow gh-comments
allow gh pr view
allow gh pr checks
allow gh pr list
allow gh pr diff
allow gh pr create
allow gh pr ready
allow gh api
ask gh api *--method * "Confirm: gh api mutating request — verify endpoint and payload"
ask gh api *-X * "Confirm: gh api mutating request — verify endpoint and payload"
ask gh api *-f * "Confirm: gh api mutating request (implicit POST via -f) — verify endpoint and payload"
ask gh api *-F * "Confirm: gh api mutating request (implicit POST via -F) — verify endpoint and payload"
ask gh api *--field * "Confirm: gh api mutating request (implicit POST via --field) — verify endpoint and payload"
ask gh api *--field=* "Confirm: gh api mutating request (implicit POST via --field=) — verify endpoint and payload"
ask gh api *--raw-field * "Confirm: gh api mutating request (implicit POST via --raw-field) — verify endpoint and payload"
ask gh api *--raw-field=* "Confirm: gh api mutating request (implicit POST via --raw-field=) — verify endpoint and payload"
ask gh api *--input * "Confirm: gh api mutating request (body from file) — verify endpoint and payload"
ask gh api *--input=* "Confirm: gh api mutating request (body from file) — verify endpoint and payload"
allow gh run
allow gh search
allow git-clean-branches
allow mise ls
allow mise ls-remote
allow mise current
allow mise which
allow mise where
allow dev
allow tmux
allow smug
allow rubocop
allow bundle show
allow bundle info

set log-full
