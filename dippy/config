# Mutations explicitly allowed in Claude Code settings.json
# Dippy's built-in handlers consider these unsafe, but they're
# standard workflow commands that shouldn't require prompting.

# Git mutations
allow git add
allow git commit
allow git switch
allow git pull
allow git stash list
allow git stash show
allow git mv
allow git absorb

# Filesystem
allow touch
allow mkdir

# Project tools
allow mix
allow just
allow bundle exec rspec
allow bundle exec rubocop
allow bundle exec rails runner
allow bin/spring
allow spring
allow bin/rails db:migrate:status
allow bin/rails runner
allow bin/packwerk check
allow yarn run
allow yarn test
allow npx playwright test
allow git-commit-context
allow safe-python
allow claude-retro
allow gh-comments
allow dev
allow tmux
allow smug
allow rubocop
allow bundle show
allow bundle info

set log-full
